{
  "name": "mvgsm-goal-manager",
  "version": "1.3.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "build": "npm run build --workspace=apps/web",
    "db:migrate": "npm run db:init --workspace=apps/api"
  }
}
