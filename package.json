{
  "name": "mvgsm-goal-manager",
  "version": "1.3.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "build": "npm run build --workspace=apps/web",
    "db:migrate": "npm run db:init --workspace=apps/api"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.21.0"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5"
  }
}
